page {
  min-height: 100%;
  background: #0f172a;
  color: #e2e8f0;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  padding: 32rpx 24rpx 48rpx;
}

.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(30, 41, 59, 0.96));
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.28);
}

.primary-button,
.secondary-button {
  width: 100%;
  min-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button {
  color: #f8fafc;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
}

.primary-button::after,
.secondary-button::after {
  border: none;
}

.secondary-button {
  color: #e2e8f0;
  background: rgba(51, 65, 85, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.compact-button {
  width: auto;
  min-width: 220rpx;
  padding: 0 30rpx;
}

.muted-text {
  color: #94a3b8;
  line-height: 1.6;
}

.badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.badge--neutral {
  color: #cbd5e1;
  background: rgba(51, 65, 85, 0.78);
}

.badge--success {
  color: #dcfce7;
  background: rgba(22, 163, 74, 0.32);
}

.badge--warning {
  color: #fef3c7;
  background: rgba(217, 119, 6, 0.3);
}

.badge--danger {
  color: #fee2e2;
  background: rgba(220, 38, 38, 0.28);
}

.tone-up {
  color: #22c55e;
}

.tone-down {
  color: #f87171;
}

.tone-flat {
  color: #facc15;
}

.tone-muted {
  color: #94a3b8;
}
