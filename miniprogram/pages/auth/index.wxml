<view class="page">
  <view class="section-card auth-card">
    <view class="auth-title">微信身份入口</view>
    <view class="muted-text">
      通过 wx.login 获取小程序 code，再交给后端 `/api/auth/wechat/*` 绑定到稳定内部账号。
    </view>
  </view>

  <view class="section-card status-card">
    <view class="status-row">
      <text class="status-label">API 配置</text>
      <text class="badge {{apiReady ? 'badge--success' : 'badge--warning'}}">
        {{apiReady ? '已填写' : '仍为占位'}}
      </text>
    </view>
    <view class="status-row">
      <text class="status-label">登录状态</text>
      <text class="badge {{loggedIn ? 'badge--success' : 'badge--neutral'}}">
        {{loggedIn ? '已登录' : '未登录'}}
      </text>
    </view>
    <view class="status-row">
      <text class="status-label">当前用户</text>
      <text class="status-value">{{userText}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">微信绑定</text>
      <text class="status-value">{{bindStatusText}}</text>
    </view>
  </view>

  <view class="section-card status-card" wx:if="{{errorMessage}}">
    <view class="status-title">操作失败</view>
    <view class="muted-text">{{errorMessage}}</view>
  </view>

  <view class="button-stack">
    <button
      class="primary-button"
      bindtap="handleWechatLogin"
      loading="{{loading}}"
      disabled="{{loading || !apiReady}}"
    >
      微信一键登录
    </button>
    <button
      class="secondary-button"
      bindtap="handleWechatBind"
      loading="{{loading}}"
      disabled="{{loading || !loggedIn}}"
    >
      绑定当前账号到微信
    </button>
    <button
      class="secondary-button"
      bindtap="handleWechatUnbind"
      loading="{{loading}}"
      disabled="{{loading || !loggedIn}}"
    >
      解除微信绑定
    </button>
    <button class="secondary-button" bindtap="handleLogout" disabled="{{loading || !loggedIn}}">退出本地登录</button>
    <button class="secondary-button" bindtap="handleOpenSettings">运行设置</button>
    <button class="primary-button" bindtap="handleOpenWatch" disabled="{{!loggedIn}}">进入盯盘首页</button>
  </view>
</view>
