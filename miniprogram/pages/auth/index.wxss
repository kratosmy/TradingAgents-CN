.auth-card,
.status-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.auth-title,
.status-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #f8fafc;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.status-label {
  color: #94a3b8;
  font-size: 26rpx;
}

.status-value {
  color: #e2e8f0;
  font-size: 26rpx;
  text-align: right;
}

.button-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
