.hero-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero-subtitle {
  color: #cbd5e1;
  line-height: 1.7;
}

.hero-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
}

.watch-card__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.watch-card__title {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.stock-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
}

.stock-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.stock-code {
  color: #93c5fd;
  font-size: 24rpx;
  font-family: 'SFMono-Regular', monospace;
}

.watch-card__metrics {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.price-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
}

.change-text {
  font-size: 26rpx;
}

.summary-block {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.block-title {
  font-size: 24rpx;
  color: #cbd5e1;
  font-weight: 600;
}

.summary-text {
  line-height: 1.7;
  color: #e2e8f0;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.notes-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 20rpx;
}

.watch-card__footer {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}
