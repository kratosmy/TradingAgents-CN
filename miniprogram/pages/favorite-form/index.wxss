.form-card,
.status-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-title,
.status-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
}

.field-label {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #cbd5e1;
}

.field-input,
.field-textarea {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  color: #f8fafc;
}

.field-textarea {
  min-height: 180rpx;
}

.picker-value {
  min-height: 84rpx;
  line-height: 40rpx;
}
