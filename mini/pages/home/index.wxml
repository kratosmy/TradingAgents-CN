<view class="shell-page">
  <shell-chrome chrome="{{chrome}}" />

  <view class="shell-surface-card">
    <text class="shell-section-heading">{{roleTitle}}</text>
    <text class="shell-copy">{{roleCopy}}</text>
    <text class="shell-support-copy">{{overviewHeadline}}</text>
    <text class="shell-copy">{{overviewCopy}}</text>
  </view>

  <view class="shell-metrics-grid">
    <view wx:for="{{overviewMetrics}}" wx:key="label" class="shell-surface-card shell-metric-card">
      <text class="shell-metric-label">{{item.label}}</text>
      <text class="shell-metric-value">{{item.value}}</text>
    </view>
  </view>

  <view class="shell-surface-card shell-highlight-card">
    <view class="shell-card-header">
      <view class="shell-link-copy">
        <text class="shell-section-heading">{{highlightTitle}}</text>
        <text class="shell-copy">{{highlightCopy}}</text>
      </view>
      <text class="shell-badge shell-badge--{{featuredBadgeTone || 'neutral'}}">{{featuredBadgeLabel}}</text>
    </view>

    <view wx:if="{{hasFeaturedCard}}" class="shell-highlight-stack">
      <text class="shell-highlight-title">{{featuredCard.stockName}} · {{featuredCard.stockCode}}</text>
      <text class="shell-copy">{{featuredCard.summary}}</text>
      <text class="shell-support-copy">{{featuredCard.market}} · {{featuredCard.board}} · {{featuredCard.exchange}}</text>
      <text class="shell-support-copy">{{sessionUserLabel}}</text>
    </view>

    <view wx:else class="shell-empty-stack">
      <text class="shell-copy">Home 不展示完整的受保护摘要堆栈；请前往 Watch 查看登录与详情卡片。</text>
      <text class="shell-support-copy">{{sessionUserLabel}}</text>
    </view>
  </view>

  <view class="shell-surface-card">
    <text class="shell-section-heading">Quick actions</text>
    <text class="shell-copy">{{quickActionCopy}}</text>
    <view class="shell-action-row">
      <button class="shell-primary-action" bindtap="onOpenWatch">{{watchButtonLabel}}</button>
      <button class="shell-secondary-action" bindtap="onOpenAccount">{{accountButtonLabel}}</button>
    </view>
  </view>

  <view class="shell-surface-card">
    <text class="shell-section-heading">Placeholder runtime posture</text>
    <text class="shell-copy">checked-in mode：{{runtimeBoundary.mode}}</text>
    <text class="shell-copy">checked-in baseUrl：{{runtimeBoundary.baseUrl}}</text>
    <text class="shell-support-copy">{{runtimeBoundary.disclosure}}</text>
  </view>
</view>
