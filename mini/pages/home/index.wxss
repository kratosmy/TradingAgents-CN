.page-shell {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.disclaimer-card,
.hero-card,
.auth-card,
.contract-card,
.empty-state-card,
.digest-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.disclaimer-card {
  border: 2rpx solid rgba(245, 158, 11, 0.35);
  background: #fffaf0;
  gap: 12rpx;
  display: flex;
  flex-direction: column;
}

.badge-row,
.stock-row,
.card-header,
.quote-row,
.meta-row,
.auth-header,
.session-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.badge-row,
.stock-row {
  justify-content: flex-start;
  gap: 12rpx;
}

.badge,
.checkpoint-chip,
.risk-pill,
.change-pill,
.metric-pill,
.error-chip {
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
}

.badge--info {
  color: #1d4ed8;
  background: rgba(37, 99, 235, 0.12);
}

.badge--warn {
  color: #b45309;
  background: rgba(245, 158, 11, 0.16);
}

.badge--status {
  text-transform: uppercase;
}

.badge--auth-required {
  color: #b45309;
  background: rgba(245, 158, 11, 0.16);
}

.badge--authenticated {
  color: #15803d;
  background: rgba(34, 197, 94, 0.12);
}

.badge--checking {
  color: #1d4ed8;
  background: rgba(37, 99, 235, 0.12);
}

.disclaimer-copy,
.evidence-copy,
.hero-subtitle,
.summary-copy,
.stock-market,
.meta-row,
.status-label,
.auth-message,
.empty-state-copy,
.session-copy,
.error-copy {
  color: #475569;
  line-height: 1.6;
}

.hero-card {
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  color: #ffffff;
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.84;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric-pill {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
}

.checkpoint-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.checkpoint-chip {
  color: #0f172a;
  background: rgba(148, 163, 184, 0.16);
}

.auth-card,
.contract-card,
.empty-state-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.auth-title,
.contract-title,
.empty-state-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.auth-message,
.contract-copy,
.empty-state-copy {
  display: block;
  margin-top: 8rpx;
}

.form-stack,
.error-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.auth-input {
  width: 100%;
  border: 2rpx solid rgba(148, 163, 184, 0.3);
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.primary-button,
.ghost-button {
  margin: 0;
  border-radius: 18rpx;
  font-size: 26rpx;
}

.primary-button {
  background: #2563eb;
  color: #ffffff;
}

.ghost-button {
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
}

.error-chip {
  width: fit-content;
  color: #b91c1c;
  background: rgba(239, 68, 68, 0.12);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contract-card {
  border: 2rpx solid rgba(37, 99, 235, 0.16);
  background: rgba(239, 246, 255, 0.8);
}

.stock-name,
.current-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.stock-code {
  color: #64748b;
}

.risk-pill--positive {
  color: #15803d;
  background: rgba(34, 197, 94, 0.12);
}

.risk-pill--warning {
  color: #b45309;
  background: rgba(245, 158, 11, 0.16);
}

.risk-pill--neutral {
  color: #475569;
  background: rgba(148, 163, 184, 0.16);
}

.quote-row {
  margin-top: 20rpx;
}

.change-pill--up {
  color: #15803d;
  background: rgba(34, 197, 94, 0.12);
}

.change-pill--down {
  color: #b91c1c;
  background: rgba(239, 68, 68, 0.12);
}

.change-pill--flat {
  color: #475569;
  background: rgba(148, 163, 184, 0.16);
}

.summary-copy {
  display: block;
  margin-top: 20rpx;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.status-item {
  background: rgba(148, 163, 184, 0.08);
  border-radius: 18rpx;
  padding: 16rpx;
}

.status-label {
  font-size: 20rpx;
  display: block;
}

.status-value {
  margin-top: 8rpx;
  display: block;
  font-weight: 700;
  color: #0f172a;
}

.meta-row {
  margin-top: 20rpx;
  font-size: 22rpx;
}
